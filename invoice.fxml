<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.oop_project.InvoiceController">
    <children>
        <VBox styleClass="card" maxWidth="500.0" maxHeight="500.0" spacing="20.0">
            <children>
                <Label text="Checkout &amp; Payment" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e3c72;"/>
                <Separator />
                
                <HBox>
                    <Label text="Guest Name: " style="-fx-font-weight: bold; -fx-text-fill: #6c757d;"/>
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="guestNameLabel" text="Loading..." style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
                </HBox>
                
                <HBox>
                    <Label text="Total Amount Due: " style="-fx-font-weight: bold; -fx-text-fill: #6c757d;"/>
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="totalAmountLabel" text="0.00 EGP" style="-fx-font-weight: bold; -fx-font-size: 20px; -fx-text-fill: #2a5298;"/>
                </HBox>
                
                <Separator />
                
                <Label text="Select Payment Method" style="-fx-text-fill: #495057;"/>
                <ChoiceBox fx:id="choiceBox" prefWidth="440.0" prefHeight="40.0" style="-fx-background-color: #f8f9fa; -fx-border-color: #dee2e6; -fx-border-radius: 5px;"/>
                
                <Label fx:id="statusLabel" alignment="CENTER" prefWidth="440.0" style="-fx-font-weight: bold;"/>
                
                <Region VBox.vgrow="ALWAYS" />
                
                <HBox spacing="15.0">
                    <children>
                        <Button text="Cancel" style="-fx-background-color: #e0e0e0; -fx-text-fill: #333;" prefWidth="210.0" prefHeight="45.0" onAction="#goBack"/>
                        <Button text="Confirm Payment" styleClass="btn-primary" prefWidth="215.0" prefHeight="45.0" onAction="#payNow"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</StackPane>
