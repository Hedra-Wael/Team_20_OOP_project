<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.oop_project.GuestDashboardController">
    <left>
        <VBox styleClass="sidebar" prefWidth="250.0">
            <children>
                <Label text="Hotel Oasis" styleClass="sidebar-title"/>
                <Region prefHeight="20.0"/>
                <Button text="Dashboard" styleClass="sidebar-btn" prefWidth="250.0"/>
                <Button fx:id="browseRoomsButton" text="Book a Room" styleClass="sidebar-btn" prefWidth="250.0" onAction="#goToRoomBrowser"/>
                
                <Button fx:id="checkoutButton" text="Pay Selected Booking" styleClass="sidebar-btn" prefWidth="250.0" onAction="#goToCheckout"/>
                
                <Region VBox.vgrow="ALWAYS"/>
                <Button fx:id="logoutButton" text="Log Out" styleClass="sidebar-btn" prefWidth="250.0" onAction="#handleLogout"/>
            </children>
        </VBox>
    </left>
    
    <center>
        <VBox spacing="30.0" style="-fx-padding: 40px;">
            <children>
                <HBox spacing="30.0">
                    <children>
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Welcome Back" styleClass="stat-label"/>
                                <Label fx:id="welcomeLabel" text="Guest" styleClass="stat-value"/>
                            </children>
                        </VBox>
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" style="-fx-background-color: linear-gradient(to right, #11998e, #38ef7d);">
                            <children>
                                <Label text="Available Balance" styleClass="stat-label"/>
                                <Label fx:id="balanceLabel" text="0.0 EGP" styleClass="stat-value"/>
                            </children>
                        </VBox>
                    </children>
                </HBox>
                
                <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="15.0">
                    <children>
                        <Label text="Your Active Reservations" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #343a40;"/>
                        <TableView fx:id="reservationsTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colResId" prefWidth="120.0" text="Booking ID" />
                                <TableColumn fx:id="colRoom" prefWidth="120.0" text="Room Number" />
                                <TableColumn fx:id="colCheckIn" prefWidth="200.0" text="Check-In Date" />
                                <TableColumn fx:id="colStatus" prefWidth="150.0" text="Status" />
                            </columns>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>
</BorderPane>
