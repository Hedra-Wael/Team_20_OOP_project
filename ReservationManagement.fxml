<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="900.0" prefWidth="1600.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <VBox layoutX="50.0" layoutY="30.0" spacing="20.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="50.0" AnchorPane.rightAnchor="50.0" AnchorPane.topAnchor="30.0">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <children>
                        <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Reservation Management">
                            <font>
                                <Font name="System Bold" size="36.0" />
                            </font>
                        </Text>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="NewReservation" mnemonicParsing="false" prefHeight="50.0" prefWidth="220.0" text="Add New Reservation">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Button>
                    </children>
                </HBox>

                <TableView fx:id="reservationTable" style="-fx-selection-bar: #bdc3c7;" VBox.vgrow="ALWAYS">
                    <columns>
                  <TableColumn fx:id="CoulmnN" prefWidth="24.23473358154297" text="N" />
                        <TableColumn prefWidth="201.26524353027344" text="ID" />
                        <TableColumn prefWidth="250.0" text="Guest Name" />
                        <TableColumn prefWidth="150.0" text="Room" />
                        <TableColumn prefWidth="200.0" text="Check-in" />
                        <TableColumn prefWidth="200.0" text="Check-out" />
                        <TableColumn prefWidth="150.0" text="Price" />
                        <TableColumn prefWidth="150.0" text="Status" />
                    </columns>
                </TableView>

                <HBox alignment="CENTER_RIGHT" spacing="15.0">
                    <children>
                        <Button fx:id="Cancle" mnemonicParsing="false" prefHeight="45.0" prefWidth="150.0" text="Cancel " />
                        <Button fx:id="ViewDetais" mnemonicParsing="false" prefHeight="45.0" prefWidth="150.0" text="View Details" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
