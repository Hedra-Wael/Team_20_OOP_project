<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="15.0" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.oop_project.LoginController">
   <children>
      <Label text="Hotel Reservation System - Login" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
      <TextField fx:id="usernameField" promptText="Enter Username" maxWidth="250.0"/>
      <PasswordField fx:id="passwordField" promptText="Enter Password" maxWidth="250.0"/>
      <HBox alignment="CENTER" spacing="20.0">
         <children>
            <Button text="Login" fx:id="loginButton" onAction="#handleLogin"/>
            <Button text="Register" fx:id="registerButton" onAction="#handleRegister"/>
         </children>
      </HBox>
      <Label fx:id="errorLabel" textFill="RED"/>
   </children>
</VBox>
