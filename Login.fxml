<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="400.0" prefWidth="600.0" spacing="15.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.oop_project.SceneController">
   <children>
      <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Hotel Reservation System - Login" />
      <TextField fx:id="usernameField" maxWidth="250.0" promptText="Enter Username" />
      <PasswordField fx:id="passwordField" maxWidth="250.0" promptText="Enter Password" />
      <HBox alignment="CENTER" spacing="20.0">
         <children>
            <Button fx:id="loginButton" onAction="#switchToRoomBrowser" text="Login" />
            <Button fx:id="registerButton" onAction="#handleRegister" text="Register" />
         </children>
      </HBox>
      <Label fx:id="errorLabel" textFill="RED" />
   </children>
</VBox>
